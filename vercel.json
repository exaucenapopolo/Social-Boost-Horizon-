{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/exo-services",
      "destination": "/api/exo-services.js"
    },
    {
      "source": "/api/create-swychr",
      "destination": "/api/create-swychr.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
