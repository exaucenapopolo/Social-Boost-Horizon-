{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/exo-services", "destination": "/api/exo-services.js" },
    { "source": "/api/webhook-swychr", "destination": "/api/webhook-swychr.js" },
    { "source": "/api/register", "destination": "/api/register.js" },
    { "source": "/api/order-exo", "destination": "/api/order-exo.js" },
    { "source": "/api/exo-status", "destination": "/api/exo-status.js" },
    { "source": "/api/exo-cancel", "destination": "/api/exo-cancel.js" },
    { "source": "/api/confirm-swychr", "destination": "/api/confirm-swychr.js" },
    { "source": "/api/create-swychr", "destination": "/api/create-swychr.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ]
}
